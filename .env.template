# idig-server runtime configuration.
# Copy to .env and fill in. .env is gitignored.

# Project bootstrap (used by entrypoint.sh on first start only).
PROJECT_NAME=KNS-Dhaskalio
ADMIN_USER=admin
ADMIN_PASSWORD=replace-me

# Where the bare git repos live on the host. Mounted at /data inside
# the container.
IDIG_DATA_DIR=./data

# Host port the server is published on (container always listens on 9000).
IDIG_SERVER_PORT=9000

# Optional: notify the IKAROS bridge after every successful push.
# Leave both blank to disable. Secret must match IDIG_WEBHOOK_SECRET in
# the ikaros-mima .env. Generate with:  openssl rand -hex 32
IDIG_WEBHOOK_URL=
IDIG_WEBHOOK_SECRET=
